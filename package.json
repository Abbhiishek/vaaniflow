{
  "name": "vaaniflow",
  "productName": "Vaani",
  "version": "1.0.6",
  "description": "Voice dictation for Windows with server-owned Azure OpenAI deployments and optional provider overrides.",
  "main": "src/main/main.js",
  "author": "Abhishek Kushwaha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abbhiishek/vaaniflow.git"
  },
  "scripts": {
    "start": "electron .",
    "smoke": "electron . --smoke",
    "test": "node --test",
    "server:dev": "npm --prefix server run dev",
    "server:check": "npm --prefix server run check",
    "server:deploy": "npm --prefix server run deploy",
    "gateway:config": "node scripts/generate-gateway-config.js",
    "predist": "npm run gateway:config",
    "verify:release": "node scripts/verify-release.js",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.vaani.flow",
    "productName": "Vaani",
    "artifactName": "Vaani-Setup-${version}.${ext}",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "afterPack": "scripts/after-pack.js",
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Abbhiishek",
      "repo": "vaaniflow",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/vaani.png"
    },
    "nsis": {
      "guid": "8429a095-bee6-5aa8-8eb3-4fefd8b092a1",
      "oneClick": true,
      "runAfterFinish": true,
      "shortcutName": "Vaani",
      "uninstallDisplayName": "Vaani ${version}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
