---
import mark from '../assets/brand/vaaniflow-mark.svg';

interface Props {
  descriptor?: boolean;
  compact?: boolean;
}

const { descriptor = false, compact = false } = Astro.props;
---

<span class:list={['brand', { 'brand--compact': compact }]}>
  <img src={mark.src} width={compact ? 32 : 38} height={compact ? 32 : 38} alt="" />
  <span class="brand__copy">
    <strong>VaaniFlow</strong>
    {descriptor && <small>Home of Vaani for Windows</small>}
  </span>
</span>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    line-height: 1;
  }

  .brand img {
    flex: 0 0 auto;
    border-radius: 10px;
  }

  .brand__copy {
    display: grid;
    gap: 0.25rem;
  }

  strong {
    font-size: 0.94rem;
    font-weight: 780;
    letter-spacing: -0.03em;
  }

  small {
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .brand--compact {
    gap: 0.62rem;
  }

  @media (max-width: 719px) {
    small {
      display: none;
    }
  }
</style>
