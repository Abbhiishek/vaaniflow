---
import SectionHeading from './SectionHeading.astro';
import { productFacts } from '../data/home';
import { siteConfig } from '../config';
---

<section class="product-proof" id="product" aria-labelledby="product-proof-title">
  <div class="shell">
    <SectionHeading
      id="product-proof-title"
      label="The desktop workflow"
      title="Vaani stays out of the way until you speak."
      description="Vaani is the Windows application. VaaniFlow is the open-source project behind it. The app listens on demand, processes the result, then returns you to the work already open."
    />

    <figure class="workspace" aria-labelledby="workspace-caption">
      <div class="workspace__chrome" aria-hidden="true">
        <span></span><span></span><span></span>
        <p>Project notes — Draft</p>
        <i>Windows</i>
      </div>

      <div class="workspace__body" aria-hidden="true">
        <aside>
          <p>Notes</p>
          <span class="is-active">Project brief</span>
          <span>Weekly review</span>
          <span>Follow-up</span>
          <span>Ideas</span>
        </aside>

        <div class="editor">
          <p class="editor__label">Project brief</p>
          <h3>Next steps</h3>
          <div class="editor__copy">
            <span class="line line--wide"></span>
            <span class="line line--medium"></span>
            <p>Could you send the revised plan tomorrow morning?<i></i></p>
            <span class="line line--short"></span>
          </div>
        </div>

        <div class="flow-bar">
          <div class="flow-bar__mark">
            <span></span><span></span><span></span><span></span><span></span>
          </div>
          <div>
            <strong>Ready to insert</strong>
            <small>42 words · 18 seconds</small>
          </div>
          <b>✓</b>
        </div>
      </div>

      <figcaption id="workspace-caption">
        A product interaction preview: hold <kbd>Ctrl</kbd> + <kbd>Win</kbd>, speak from a text field, and release to insert the transcript.
      </figcaption>
    </figure>

    <div class="fact-grid" aria-label="Vaani product facts">
      {productFacts.map((fact, index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{fact.title}</h3>
          <p>{fact.description}</p>
        </article>
      ))}
    </div>

    <p class="product-proof__note">
      {siteConfig.productName} has no hosted VaaniFlow account or sync service. Provider requests go directly to the Azure OpenAI resource you configure.
    </p>
  </div>
</section>

<style>
  .product-proof {
    padding-block: var(--space-10);
    border-top: 1px solid var(--color-rule);
    background: var(--color-void);
  }

  .workspace {
    margin: var(--space-8) 0 0;
    overflow: hidden;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-md);
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
  }

  .workspace__chrome {
    display: grid;
    min-height: 54px;
    grid-template-columns: repeat(3, 10px) 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 0 var(--space-4);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-elevated);
  }

  .workspace__chrome > span {
    width: 9px;
    height: 9px;
    border: 1px solid var(--color-steel);
    border-radius: 50%;
  }

  .workspace__chrome p,
  .workspace__chrome i {
    margin: 0;
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-style: normal;
  }

  .workspace__chrome p {
    padding-left: var(--space-3);
  }

  .workspace__body {
    position: relative;
    display: grid;
    min-height: 600px;
    grid-template-columns: minmax(170px, 0.24fr) 1fr;
    background:
      linear-gradient(90deg, rgba(242, 244, 245, 0.035) 1px, transparent 1px),
      var(--color-white);
    background-size: 18% 100%;
  }

  aside {
    display: grid;
    align-content: start;
    gap: 0.25rem;
    padding: var(--space-5) var(--space-4);
    border-right: 1px solid var(--color-rule);
    background: #121416;
  }

  aside p {
    margin: 0 0 var(--space-3);
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  aside span {
    padding: 0.72rem 0.85rem;
    border-radius: 6px;
    color: var(--color-steel);
    font-size: 0.76rem;
    font-weight: 650;
  }

  aside .is-active {
    background: var(--color-white);
    color: var(--color-ink);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.035);
  }

  .editor {
    width: min(720px, calc(100% - 64px));
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7.5rem) 0 9rem;
  }

  .editor__label {
    margin-bottom: var(--space-3);
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .editor h3 {
    margin-bottom: var(--space-5);
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    font-variation-settings: 'wdth' 88;
    font-weight: 610;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  .editor__copy {
    display: grid;
    gap: 1.25rem;
  }

  .line {
    display: block;
    height: 1px;
    background: var(--color-rule);
  }

  .line--wide {
    width: 88%;
  }

  .line--medium {
    width: 67%;
  }

  .line--short {
    width: 42%;
  }

  .editor__copy p {
    max-width: 620px;
    margin: var(--space-3) 0;
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3.2vw, 3.15rem);
    font-variation-settings: 'wdth' 92;
    font-weight: 520;
    letter-spacing: -0.045em;
    line-height: 1.1;
  }

  .editor__copy p i {
    display: inline-block;
    width: 3px;
    height: 1em;
    margin-left: 0.15em;
    transform: translateY(0.12em);
    background: var(--color-ink);
    animation: caret 1s steps(1) infinite;
  }

  .flow-bar {
    position: absolute;
    bottom: var(--space-5);
    left: 50%;
    display: grid;
    width: min(420px, calc(100% - 40px));
    min-height: 76px;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: 0.9rem 1rem;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 18px;
    background: #080a0b;
    color: var(--color-ink);
    box-shadow: 0 18px 55px rgba(0, 0, 0, 0.5);
  }

  .flow-bar__mark {
    display: flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    gap: 3px;
    border-radius: 12px;
    background: var(--color-ink);
  }

  .flow-bar__mark span {
    width: 2px;
    height: var(--height, 16px);
    border-radius: 3px;
    background: var(--color-void);
  }

  .flow-bar__mark span:nth-child(1),
  .flow-bar__mark span:nth-child(5) {
    height: 8px;
  }

  .flow-bar__mark span:nth-child(2),
  .flow-bar__mark span:nth-child(4) {
    height: 18px;
  }

  .flow-bar__mark span:nth-child(3) {
    height: 27px;
  }

  .flow-bar > div:nth-child(2) {
    display: grid;
    gap: 0.2rem;
  }

  .flow-bar strong {
    font-size: 0.78rem;
  }

  .flow-bar small {
    color: #aeb6bb;
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .flow-bar b {
    display: grid;
    width: 32px;
    height: 32px;
    place-content: center;
    border-radius: 50%;
    background: var(--color-ink);
    color: var(--color-void);
    font-size: 0.76rem;
  }

  figcaption {
    padding: var(--space-4);
    border-top: 1px solid var(--color-rule);
    color: var(--color-steel);
    font-size: 0.78rem;
  }

  kbd {
    padding: 0.18rem 0.4rem;
    border: 1px solid var(--color-rule);
    border-bottom-color: var(--color-steel);
    border-radius: 4px;
    background: var(--color-paper);
    color: var(--color-graphite);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  .fact-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: var(--space-7);
    border-top: 1px solid var(--color-ink);
  }

  .fact-grid article {
    min-height: 220px;
    padding: var(--space-4) var(--space-4) var(--space-5) 0;
    border-right: 1px solid var(--color-rule);
  }

  .fact-grid article:not(:first-child) {
    padding-left: var(--space-4);
  }

  .fact-grid article:last-child {
    border-right: 0;
  }

  .fact-grid span {
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .fact-grid h3 {
    margin: var(--space-5) 0 var(--space-3);
    font-size: 1.42rem;
    font-variation-settings: 'wdth' 92;
    font-weight: 610;
    letter-spacing: -0.04em;
  }

  .fact-grid p,
  .product-proof__note {
    color: var(--color-steel);
    font-size: 0.83rem;
    line-height: 1.6;
  }

  .fact-grid p {
    margin: 0;
  }

  .product-proof__note {
    max-width: 700px;
    margin: var(--space-5) 0 0 auto;
  }

  @keyframes caret {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 900px) {
    .fact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .fact-grid article:nth-child(2) {
      border-right: 0;
    }

    .fact-grid article:nth-child(-n + 2) {
      border-bottom: 1px solid var(--color-rule);
    }
  }

  @media (max-width: 719px) {
    .workspace {
      margin-top: var(--space-7);
      border-radius: var(--radius-sm);
    }

    .workspace__chrome {
      grid-template-columns: repeat(3, 8px) 1fr;
      padding-inline: var(--space-3);
    }

    .workspace__chrome i,
    aside {
      display: none;
    }

    .workspace__body {
      min-height: 520px;
      grid-template-columns: 1fr;
      background: var(--color-white);
    }

    .editor {
      width: calc(100% - 40px);
      padding-top: var(--space-7);
    }

    .flow-bar {
      bottom: var(--space-3);
    }

    .fact-grid {
      grid-template-columns: 1fr;
    }

    .fact-grid article,
    .fact-grid article:not(:first-child) {
      min-height: 0;
      padding: var(--space-4) 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-rule);
    }

    .fact-grid article:nth-child(-n + 2) {
      border-bottom: 1px solid var(--color-rule);
    }

    .fact-grid h3 {
      margin-top: var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .editor__copy p i {
      animation: none;
    }
  }
</style>
