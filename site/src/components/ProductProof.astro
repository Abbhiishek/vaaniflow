---
import SectionHeading from './SectionHeading.astro';
import { productFacts } from '../data/home';
import { siteConfig } from '../config';
---

<section class="product-proof" id="product" aria-labelledby="product-proof-title">
  <div class="shell">
    <SectionHeading
      id="product-proof-title"
      label="The desktop workflow"
      title="Vaani stays out of the way until you speak."
      description="Vaani is the Windows application. VaaniFlow is the open-source project behind it. The app listens on demand, processes the result, then returns you to the work already open."
    />

    <figure class="workspace" aria-labelledby="workspace-caption" data-reveal="scale">
      <div class="workspace__frame">
        <div class="workspace__chrome" aria-hidden="true">
          <div><span></span><span></span><span></span></div>
          <p>Vaani · Insights</p>
          <i>Windows</i>
        </div>
        <div class="workspace__image">
          <img
            src="/product/vaani-insights.png"
            width="1125"
            height="741"
            decoding="async"
            alt="Vaani Insights dashboard showing local dictation totals, time saved, consistency, and recent voice activity"
          />
        </div>
      </div>

      <figcaption id="workspace-caption">
        A product interaction preview: hold <kbd>Ctrl</kbd> + <kbd>Win</kbd>, speak from a text field, and release to insert the transcript.
      </figcaption>
    </figure>

    <div class="fact-grid" aria-label="Vaani product facts">
      {productFacts.map((fact, index) => (
        <article data-reveal style={`--reveal-delay: ${index * 60}ms`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{fact.title}</h3>
          <p>{fact.description}</p>
        </article>
      ))}
    </div>

    <p class="product-proof__note" data-reveal style={`--reveal-delay: ${productFacts.length * 60}ms`}>
      {siteConfig.productName} has no hosted VaaniFlow account or sync service. Provider requests go directly to the Azure OpenAI resource you configure.
    </p>
  </div>
</section>

<style>
  .product-proof {
    padding-block: var(--space-10);
    border-top: 1px solid var(--color-rule);
    background: var(--color-void);
  }

  .workspace {
    margin: var(--space-8) 0 0;
  }

  .workspace__frame {
    overflow: hidden;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--duration-base) ease,
      transform var(--duration-base) var(--ease-out-strong);
  }

  .workspace__chrome {
    display: grid;
    min-height: 54px;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-3);
    padding: 0 var(--space-4);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-elevated);
  }

  .workspace__chrome > div {
    display: flex;
    gap: 8px;
  }

  .workspace__chrome span {
    width: 9px;
    height: 9px;
    border: 1px solid var(--color-steel);
    border-radius: 50%;
  }

  .workspace__chrome p,
  .workspace__chrome i {
    margin: 0;
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-style: normal;
  }

  .workspace__chrome p {
    text-align: center;
  }

  .workspace__chrome i {
    justify-self: end;
  }

  .workspace__image {
    overflow: hidden;
    background: #101315;
  }

  .workspace__image img {
    width: 100%;
    height: auto;
    transition: transform var(--duration-base) var(--ease-out-strong);
  }

  figcaption {
    padding: var(--space-4) 0 0;
    color: var(--color-steel);
    font-size: 0.78rem;
  }

  kbd {
    padding: 0.18rem 0.4rem;
    border: 1px solid var(--color-rule);
    border-bottom-color: var(--color-steel);
    border-radius: 4px;
    background: var(--color-paper);
    color: var(--color-graphite);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  .fact-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: var(--space-7);
    border-top: 1px solid var(--color-ink);
  }

  .fact-grid article {
    min-height: 220px;
    padding: var(--space-4) var(--space-4) var(--space-5) 0;
    border-right: 1px solid var(--color-rule);
  }

  .fact-grid article:not(:first-child) {
    padding-left: var(--space-4);
  }

  .fact-grid article:last-child {
    border-right: 0;
  }

  .fact-grid span {
    color: var(--color-steel);
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .fact-grid h3 {
    margin: var(--space-5) 0 var(--space-3);
    font-size: 1.42rem;
    font-variation-settings: 'wdth' 92;
    font-weight: 610;
    letter-spacing: -0.04em;
  }

  .fact-grid p,
  .product-proof__note {
    color: var(--color-steel);
    font-size: 0.83rem;
    line-height: 1.6;
  }

  .fact-grid p {
    margin: 0;
  }

  .product-proof__note {
    max-width: 700px;
    margin: var(--space-5) 0 0 auto;
  }

  @media (hover: hover) and (pointer: fine) {
    .workspace__frame:hover {
      transform: translateY(-3px);
      border-color: var(--color-steel);
    }

    .workspace__frame:hover img {
      transform: scale(1.008);
    }
  }

  @media (max-width: 900px) {
    .fact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .fact-grid article:nth-child(2) {
      border-right: 0;
    }

    .fact-grid article:nth-child(-n + 2) {
      border-bottom: 1px solid var(--color-rule);
    }
  }

  @media (max-width: 719px) {
    .workspace {
      margin-top: var(--space-7);
    }

    .workspace__frame {
      border-radius: var(--radius-sm);
    }

    .workspace__chrome {
      min-height: 46px;
      grid-template-columns: auto 1fr;
      padding-inline: var(--space-3);
    }

    .workspace__chrome p {
      text-align: right;
    }

    .workspace__chrome i {
      display: none;
    }

    .fact-grid {
      grid-template-columns: 1fr;
    }

    .fact-grid article,
    .fact-grid article:not(:first-child) {
      min-height: 0;
      padding: var(--space-4) 0;
      border-right: 0;
      border-bottom: 1px solid var(--color-rule);
    }

    .fact-grid h3 {
      margin-top: var(--space-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .workspace__frame,
    .workspace__image img,
    .workspace__frame:hover,
    .workspace__frame:hover img {
      transform: none;
      transition-property: border-color;
      transition-duration: 180ms;
    }
  }
</style>
