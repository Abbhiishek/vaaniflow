---
import SectionHeading from './SectionHeading.astro';
import { localData, providerData } from '../data/home';
---

<section class="privacy" id="privacy" aria-labelledby="privacy-title">
  <div class="shell">
    <SectionHeading
      id="privacy-title"
      label="Clear data boundaries"
      title="Local app data. Provider-routed speech."
      description="VaaniFlow does not operate an account or sync service. Vaani stores its working data locally, while speech and optional cleanup use the Azure OpenAI resource you connect."
      inverse
    />

    <div class="privacy-flow" aria-label="How data moves through Vaani">
      <div class="flow-node">
        <span>01</span>
        <strong>Microphone</strong>
        <small>Recorded on demand</small>
      </div>
      <div class="flow-connector"><span>audio</span><i>→</i></div>
      <div class="flow-node flow-node--provider">
        <span>02</span>
        <strong>Your Whisper deployment</strong>
        <small>Transcribes the audio</small>
      </div>
      <div class="flow-connector"><span>transcript</span><i>→</i></div>
      <div class="flow-node">
        <span>03</span>
        <strong>Vaani</strong>
        <small>Processes locally</small>
      </div>
      <div class="flow-connector"><span>text</span><i>→</i></div>
      <div class="flow-node">
        <span>04</span>
        <strong>Current text field</strong>
        <small>Inserted at the cursor</small>
      </div>
    </div>

    <p class="optional-flow">
      Optional path: transcript → your configured language-model deployment → cleaned or styled text → Vaani
    </p>

    <div class="privacy-lists">
      <article>
        <h3>Stays on this device</h3>
        <ul>
          {localData.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article>
        <h3>Sent when the feature runs</h3>
        <ul>
          {providerData.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>

    <p class="privacy__disclosure">
      Azure availability, rate limits, and usage charges are governed by the Azure resource you connect. VaaniFlow does not proxy these requests or add a hosted subscription.
    </p>
  </div>
</section>

<style>
  .privacy {
    padding-block: var(--space-10);
    border-block: 1px solid var(--color-rule);
    background: #060708;
    color: var(--color-ink);
  }

  .privacy-flow {
    display: grid;
    grid-template-columns: 1fr auto 1.2fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: 0;
    margin-top: var(--space-8);
    border-block: 1px solid rgba(255, 255, 255, 0.22);
  }

  .flow-node {
    display: grid;
    min-height: 190px;
    align-content: center;
    gap: 0.45rem;
    padding: var(--space-4);
  }

  .flow-node--provider {
    background: var(--color-ink);
    color: var(--color-void);
  }

  .flow-node span,
  .flow-node small,
  .flow-connector span,
  .optional-flow {
    color: #9aa3aa;
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .flow-node--provider span,
  .flow-node--provider small {
    color: #555f65;
  }

  .flow-node strong {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.3vw, 2rem);
    font-variation-settings: 'wdth' 88;
    font-weight: 580;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .flow-connector {
    display: grid;
    width: clamp(56px, 7vw, 96px);
    place-content: center;
    justify-items: center;
    gap: 0.7rem;
    color: #9aa3aa;
  }

  .flow-connector i {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-style: normal;
  }

  .optional-flow {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-4);
    border-left: 2px solid var(--color-ink);
    line-height: 1.7;
  }

  .privacy-lists {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(3rem, 8vw, 8rem);
    margin-top: var(--space-8);
  }

  .privacy-lists article {
    border-top: 1px solid rgba(255, 255, 255, 0.35);
  }

  .privacy-lists h3 {
    margin: var(--space-4) 0;
    font-size: 1.2rem;
    font-variation-settings: 'wdth' 90;
    font-weight: 610;
    letter-spacing: -0.03em;
  }

  .privacy-lists ul {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .privacy-lists li {
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    color: #c5cbce;
    font-size: 0.82rem;
  }

  .privacy__disclosure {
    max-width: 720px;
    margin: var(--space-7) 0 0 auto;
    color: #9aa3aa;
    font-size: 0.78rem;
    line-height: 1.7;
  }

  @media (max-width: 980px) {
    .privacy-flow {
      grid-template-columns: 1fr;
    }

    .flow-node {
      min-height: 135px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .flow-connector {
      width: auto;
      height: 70px;
    }

    .flow-connector i {
      transform: rotate(90deg);
    }
  }

  @media (max-width: 719px) {
    .privacy-lists {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
