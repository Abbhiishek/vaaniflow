---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'inverse' | 'text';
  external?: boolean;
  downloadAction?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  external = false,
  downloadAction = false,
  class: className
} = Astro.props;
---

<a
  href={href}
  class:list={['button', `button--${variant}`, className]}
  target={external ? '_blank' : undefined}
  rel={external ? 'noreferrer' : undefined}
  data-download={downloadAction ? '' : undefined}
>
  <slot name="icon" />
  <span><slot /></span>
  <svg class="button__arrow" aria-hidden="true" viewBox="0 0 18 18" width="18" height="18">
    <path d="M3.5 9h10.5m-4-4 4 4-4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
  </svg>
</a>

<style>
  .button {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.86rem 1.12rem 0.86rem 1.25rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    font-size: 0.82rem;
    font-weight: 760;
    line-height: 1;
    transition:
      color var(--duration-fast) ease,
      background var(--duration-fast) ease,
      border-color var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-out);
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button--primary {
    background: var(--color-ink);
    color: var(--color-void);
  }

  .button--primary:hover {
    background: #ffffff;
  }

  .button--secondary {
    border-color: var(--color-rule);
    background: rgba(255, 255, 255, 0.025);
    color: var(--color-ink);
  }

  .button--secondary:hover {
    border-color: #687177;
    background: var(--color-elevated);
  }

  .button--inverse {
    border-color: #687177;
    background: var(--color-ink);
    color: var(--color-void);
  }

  .button--inverse:hover {
    background: #ffffff;
  }

  .button--text {
    min-height: 44px;
    padding-inline: 0;
    border-radius: 0;
    border-bottom-color: currentColor;
  }

  .button--text:hover {
    transform: none;
  }

  .button__arrow {
    flex: 0 0 auto;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .button:hover .button__arrow {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .button:hover,
    .button:hover .button__arrow {
      transform: none;
    }
  }
</style>
