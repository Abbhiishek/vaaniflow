---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import ProductProof from '../components/ProductProof.astro';
import Workflow from '../components/Workflow.astro';
import Capabilities from '../components/Capabilities.astro';
import ProductScreens from '../components/ProductScreens.astro';
import PrivacyFlow from '../components/PrivacyFlow.astro';
import ClosingSections from '../components/ClosingSections.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../config';
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <SiteHeader />
  <main id="main">
    <Hero />
    <ProductProof />
    <Workflow />
    <Capabilities />
    <ProductScreens />
    <PrivacyFlow />
    <ClosingSections />
  </main>
  <SiteFooter />
</BaseLayout>
